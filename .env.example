# ─────────────────────────────────────────────────────────────────────────────
# NextHireAI environment variables
# Copy this file to ".env.local" and fill in real values.
# NEVER commit .env.local. Keys without NEXT_PUBLIC_ are server-only (secret).
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=anuragsingh02100@gmail.com

# Firebase — client config (safe to expose; these are public by design)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin — server only (from the service-account JSON). SECRET.
# For FIREBASE_ADMIN_PRIVATE_KEY keep the literal \n escapes on one line.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# OpenAI — server only. SECRET.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cashfree — server only. SECRET. Use sandbox during development.
CASHFREE_ENV=sandbox
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=

# Admin panel — only this email can access /admin
ADMIN_EMAIL=as3331733@gmail.com

# Session signing secret for the self-hosted auth (set a long random string in prod)
SESSION_SECRET=change-me-to-a-long-random-string

# Email (SMTP) for password-reset OTP codes. Without these, the OTP is shown
# in the reset UI for testing instead of being emailed.
# Gmail example: host=smtp.gmail.com, port=465, user=<your gmail>,
# pass=<a Google "App Password" (not your normal password)>.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NextHireAI <anuragsingh02100@gmail.com>

# Free-tier limits
FREE_AI_MONTHLY_LIMIT=5
FREE_RESUME_LIMIT=2
